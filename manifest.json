{
  "manifest_version": 3,
  "name": "Cerberus",
  "version": "1.0",
  "description": "AI-powered Phishing and Password Security",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://www.virustotal.com/*"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI CyberShield",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
  "scripts": ["background.js"]
  }
}